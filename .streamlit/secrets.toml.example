# Copy this file to .streamlit/secrets.toml (gitignored) for local Supabase use,
# OR paste these keys into the Streamlit Community Cloud app's Secrets editor.
#
# Leave them unset to fall back to local JSON files (data.json / data_sample.json).

SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_KEY = "your-service-role-key"
